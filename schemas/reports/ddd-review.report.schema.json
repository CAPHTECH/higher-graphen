{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.ddd_review.report.v1",
  "title": "HigherGraphen DDD Review Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_type",
    "report_version",
    "metadata",
    "scenario",
    "result",
    "projection"
  ],
  "properties": {
    "schema": {
      "const": "highergraphen.ddd_review.report.v1"
    },
    "report_type": {
      "const": "ddd_review"
    },
    "report_version": {
      "const": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "projection": {
      "$ref": "#/$defs/projection"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "id_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "review_status": {
      "enum": [
        "accepted",
        "unreviewed",
        "reviewed",
        "rejected"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "runtime_package",
        "runtime_crate",
        "cli_package"
      ],
      "properties": {
        "command": {
          "const": "highergraphen ddd review"
        },
        "runtime_package": {
          "const": "higher-graphen-runtime"
        },
        "runtime_crate": {
          "const": "higher_graphen_runtime"
        },
        "cli_package": {
          "const": "highergraphen-cli"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_schema",
        "review_subject",
        "source_boundary",
        "accepted_facts",
        "inferred_claims",
        "lifted_structure"
      ],
      "properties": {
        "input_schema": {
          "const": "highergraphen.ddd_review.input.v1"
        },
        "review_subject": {
          "type": "object"
        },
        "source_boundary": {
          "$ref": "#/$defs/source_boundary"
        },
        "accepted_facts": {
          "type": "array",
          "minItems": 1
        },
        "constraints": {
          "type": "array"
        },
        "reviews": {
          "type": "array"
        },
        "inferred_claims": {
          "type": "array"
        },
        "completion_hints": {
          "type": "array"
        },
        "lifted_structure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "space_id",
            "cell_ids",
            "incidence_ids",
            "context_ids",
            "morphism_summary_ids"
          ],
          "properties": {
            "space_id": {
              "$ref": "#/$defs/id"
            },
            "cell_ids": {
              "$ref": "#/$defs/id_array"
            },
            "incidence_ids": {
              "$ref": "#/$defs/id_array"
            },
            "context_ids": {
              "$ref": "#/$defs/id_array"
            },
            "morphism_summary_ids": {
              "$ref": "#/$defs/id_array"
            }
          }
        }
      }
    },
    "source_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_paths",
        "accepted_fact_boundaries",
        "inference_boundaries",
        "omitted_material",
        "information_loss"
      ],
      "properties": {
        "input_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "accepted_fact_boundaries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "inference_boundaries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "omitted_material": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "information_loss": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "accepted_fact_ids",
        "inferred_claim_ids",
        "evaluated_invariant_ids",
        "obstructions",
        "completion_candidates",
        "evidence_boundaries",
        "projection_loss",
        "review_gaps",
        "closeability",
        "source_ids"
      ],
      "properties": {
        "status": {
          "enum": [
            "issues_detected",
            "no_issues_in_snapshot",
            "unsupported_input"
          ]
        },
        "accepted_fact_ids": {
          "$ref": "#/$defs/id_array"
        },
        "inferred_claim_ids": {
          "$ref": "#/$defs/id_array"
        },
        "evaluated_invariant_ids": {
          "$ref": "#/$defs/id_array"
        },
        "obstructions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/obstruction"
          }
        },
        "completion_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/completion_candidate"
          }
        },
        "evidence_boundaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_boundary"
          }
        },
        "projection_loss": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projection_loss"
          }
        },
        "review_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/review_gap"
          }
        },
        "closeability": {
          "$ref": "#/$defs/closeability"
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        }
      }
    },
    "obstruction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "obstruction_type",
        "title",
        "target_ids",
        "witness",
        "invariant_ids",
        "evidence_ids",
        "severity",
        "confidence",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "obstruction_type": {
          "enum": [
            "boundary_semantic_loss",
            "cross_context_identity_collapse",
            "missing_boundary_mapping",
            "missing_evidence",
            "review_required",
            "projection_information_loss",
            "contradiction_candidate"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "target_ids": {
          "$ref": "#/$defs/id_array"
        },
        "witness": {
          "type": "object"
        },
        "invariant_ids": {
          "$ref": "#/$defs/id_array"
        },
        "evidence_ids": {
          "$ref": "#/$defs/id_array"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "review_status": {
          "const": "unreviewed"
        }
      }
    },
    "completion_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "candidate_type",
        "target_ids",
        "obstruction_ids",
        "suggested_change",
        "rationale",
        "provenance",
        "severity",
        "confidence",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "candidate_type": {
          "enum": [
            "boundary_mapping",
            "domain_review",
            "evidence_request",
            "model_split",
            "constraint_update"
          ]
        },
        "target_ids": {
          "$ref": "#/$defs/id_array"
        },
        "obstruction_ids": {
          "$ref": "#/$defs/id_array"
        },
        "suggested_change": {
          "type": "object"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "type": "object"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "review_status": {
          "const": "unreviewed"
        }
      }
    },
    "evidence_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "boundary_type",
        "source_ids",
        "accepted",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "boundary_type": {
          "enum": [
            "source_backed",
            "accepted_review",
            "adapter_supplied",
            "ai_inference",
            "adapter_inference",
            "missing_evidence",
            "omitted_material"
          ]
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "accepted": {
          "type": "boolean"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        }
      }
    },
    "projection_loss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "omitted_ids",
        "loss_type",
        "summary",
        "review_status"
      ],
      "properties": {
        "projection_id": {
          "$ref": "#/$defs/id"
        },
        "omitted_ids": {
          "$ref": "#/$defs/id_array"
        },
        "loss_type": {
          "enum": [
            "risk_hidden",
            "evidence_hidden",
            "review_state_hidden",
            "boundary_semantics_hidden",
            "summary_only"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "const": "unreviewed"
        }
      }
    },
    "review_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "gap_type",
        "target_ids",
        "required_review",
        "current_status",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "gap_type": {
          "enum": [
            "missing_review",
            "unaccepted_review",
            "stale_review",
            "contradictory_review"
          ]
        },
        "target_ids": {
          "$ref": "#/$defs/id_array"
        },
        "required_review": {
          "type": "string",
          "minLength": 1
        },
        "current_status": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "const": "unreviewed"
        }
      }
    },
    "closeability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closeable",
        "blocker_ids",
        "required_actions"
      ],
      "properties": {
        "closeable": {
          "type": "boolean"
        },
        "blocker_ids": {
          "$ref": "#/$defs/id_array"
        },
        "required_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review",
        "ai_view",
        "audit_trace"
      ],
      "properties": {
        "human_review": {
          "$ref": "#/$defs/projection_view"
        },
        "ai_view": {
          "$ref": "#/$defs/projection_view"
        },
        "audit_trace": {
          "$ref": "#/$defs/projection_view"
        }
      }
    },
    "projection_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "source_ids",
        "information_loss"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "represented_ids": {
          "$ref": "#/$defs/id_array"
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "information_loss": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    }
  }
}
