{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.feed.reader.report.v1",
  "title": "HigherGraphen Feed Reader Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_type",
    "report_version",
    "metadata",
    "scenario",
    "result",
    "projection"
  ],
  "properties": {
    "schema": {
      "const": "highergraphen.feed.reader.report.v1"
    },
    "report_type": {
      "const": "feed_reader"
    },
    "report_version": {
      "const": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "projection": {
      "$ref": "#/$defs/projection"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "runtime_package",
        "runtime_crate",
        "cli_package"
      ],
      "properties": {
        "command": {
          "const": "highergraphen feed reader run"
        },
        "runtime_package": {
          "const": "higher-graphen-runtime"
        },
        "runtime_crate": {
          "const": "higher_graphen_runtime"
        },
        "cli_package": {
          "const": "highergraphen-cli"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_schema",
        "source",
        "space",
        "source_feeds",
        "entries"
      ],
      "properties": {
        "input_schema": {
          "const": "highergraphen.feed.input.v1"
        },
        "source": {
          "type": "object"
        },
        "space": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "name",
            "source_feed_ids",
            "entry_ids",
            "topic_ids",
            "event_ids",
            "context_ids"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "source_feed_ids": {
              "$ref": "#/$defs/id_array"
            },
            "entry_ids": {
              "$ref": "#/$defs/id_array"
            },
            "topic_ids": {
              "$ref": "#/$defs/id_array"
            },
            "event_ids": {
              "$ref": "#/$defs/id_array"
            },
            "context_ids": {
              "$ref": "#/$defs/id_array"
            }
          }
        },
        "source_feeds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_feed"
          },
          "minItems": 1
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entry_cell"
          },
          "minItems": 1
        },
        "topics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/topic_cell"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/event_cell"
          }
        }
      }
    },
    "source_feed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "context_id",
        "title",
        "kind",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "context_id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "official",
            "community",
            "counterpoint",
            "aggregator",
            "blog",
            "news",
            "external"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "entry_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "space_id",
        "source_id",
        "dimension",
        "cell_type",
        "label",
        "published_at",
        "topic_ids",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "space_id": {
          "$ref": "#/$defs/id"
        },
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "dimension": {
          "const": 0
        },
        "cell_type": {
          "const": "feed_entry"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "topic_ids": {
          "$ref": "#/$defs/id_array"
        },
        "event_id": {
          "$ref": "#/$defs/id"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "topic_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "space_id",
        "cell_type",
        "label",
        "entry_ids",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "space_id": {
          "$ref": "#/$defs/id"
        },
        "cell_type": {
          "const": "feed_topic"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "entry_ids": {
          "$ref": "#/$defs/id_array"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "event_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "space_id",
        "cell_type",
        "label",
        "entry_ids",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "space_id": {
          "$ref": "#/$defs/id"
        },
        "cell_type": {
          "const": "feed_event"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "entry_ids": {
          "$ref": "#/$defs/id_array"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "observed_entry_ids",
        "inferred_topic_ids",
        "correspondences",
        "completion_candidates",
        "obstructions"
      ],
      "properties": {
        "status": {
          "enum": [
            "analyzed",
            "obstructions_detected"
          ]
        },
        "observed_entry_ids": {
          "$ref": "#/$defs/id_array"
        },
        "inferred_topic_ids": {
          "$ref": "#/$defs/id_array"
        },
        "inferred_event_ids": {
          "$ref": "#/$defs/id_array"
        },
        "correspondences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/correspondence"
          }
        },
        "completion_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/completion_candidate"
          }
        },
        "obstructions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/obstruction"
          }
        }
      }
    },
    "correspondence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "correspondence_type",
        "entry_ids",
        "summary",
        "confidence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "correspondence_type": {
          "enum": [
            "same_topic",
            "duplicate",
            "follow_up",
            "counterpoint"
          ]
        },
        "entry_ids": {
          "$ref": "#/$defs/id_array"
        },
        "topic_id": {
          "$ref": "#/$defs/id"
        },
        "event_id": {
          "$ref": "#/$defs/id"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "completion_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "space_id",
        "missing_type",
        "suggested_structure",
        "inferred_from",
        "rationale",
        "confidence",
        "review_status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "space_id": {
          "$ref": "#/$defs/id"
        },
        "missing_type": {
          "enum": [
            "official_source",
            "counterpoint",
            "entry_metadata",
            "timeline_context",
            "source_feed"
          ]
        },
        "suggested_structure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "structure_type",
            "summary",
            "related_ids"
          ],
          "properties": {
            "structure_id": {
              "$ref": "#/$defs/id"
            },
            "structure_type": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "related_ids": {
              "$ref": "#/$defs/id_array"
            }
          }
        },
        "inferred_from": {
          "$ref": "#/$defs/id_array"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        }
      }
    },
    "obstruction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "obstruction_type",
        "entry_ids",
        "summary",
        "severity",
        "source_ids",
        "confidence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "obstruction_type": {
          "enum": [
            "feed_content_conflict",
            "timestamp_conflict",
            "broken_source_reference",
            "topic_mismatch"
          ]
        },
        "entry_ids": {
          "$ref": "#/$defs/id_array"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ]
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeline",
        "topic_digest",
        "audit_trace"
      ],
      "properties": {
        "timeline": {
          "$ref": "#/$defs/projection_view"
        },
        "topic_digest": {
          "$ref": "#/$defs/projection_view"
        },
        "audit_trace": {
          "$ref": "#/$defs/audit_trace"
        }
      }
    },
    "projection_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "purpose",
        "summary",
        "records",
        "source_ids",
        "information_loss"
      ],
      "properties": {
        "audience": {
          "enum": [
            "human",
            "ai_agent",
            "audit"
          ]
        },
        "purpose": {
          "enum": [
            "timeline",
            "topic_digest",
            "audit_trace"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projection_record"
          }
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "information_loss": {
          "$ref": "#/$defs/information_loss_array"
        }
      }
    },
    "projection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_type",
        "summary",
        "source_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "record_type": {
          "enum": [
            "source_feed",
            "entry",
            "topic",
            "event",
            "correspondence",
            "completion_candidate",
            "obstruction"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "review_status": {
          "$ref": "#/$defs/review_status"
        }
      }
    },
    "audit_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "purpose",
        "source_ids",
        "information_loss",
        "traces"
      ],
      "properties": {
        "audience": {
          "const": "audit"
        },
        "purpose": {
          "const": "audit_trace"
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "information_loss": {
          "$ref": "#/$defs/information_loss_array"
        },
        "traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/audit_trace_record"
          },
          "minItems": 1
        }
      }
    },
    "audit_trace_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "role",
        "represented_in"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/id"
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "represented_in": {
          "type": "array",
          "items": {
            "enum": [
              "timeline",
              "topic_digest",
              "audit_trace"
            ]
          },
          "minItems": 1
        }
      }
    },
    "information_loss_array": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "source_ids"
        ],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_ids": {
            "$ref": "#/$defs/id_array"
          }
        }
      },
      "minItems": 1
    },
    "id_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "review_status": {
      "enum": [
        "accepted",
        "unreviewed",
        "rejected"
      ]
    }
  }
}
