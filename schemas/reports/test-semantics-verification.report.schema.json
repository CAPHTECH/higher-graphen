{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.test_semantics.verification.report.v1",
  "title": "HigherGraphen Test Semantics Verification Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_type",
    "report_version",
    "metadata",
    "scenario",
    "result",
    "projection"
  ],
  "properties": {
    "schema": {
      "const": "highergraphen.test_semantics.verification.report.v1"
    },
    "report_type": {
      "const": "test_semantics_verification"
    },
    "report_version": {
      "const": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "scenario": {
      "$ref": "#/$defs/scenario"
    },
    "result": {
      "$ref": "#/$defs/result"
    },
    "projection": {
      "$ref": "#/$defs/projection"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "cli_package"
      ],
      "properties": {
        "command": {
          "const": "highergraphen test-semantics verify"
        },
        "cli_package": {
          "const": "highergraphen-cli"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interpretation_schema",
        "review_schema",
        "candidate_id",
        "candidate_kind",
        "reviewer_id",
        "test_run_path",
        "candidate"
      ],
      "properties": {
        "interpretation_schema": {
          "const": "highergraphen.test_semantics.interpretation.v1"
        },
        "review_schema": {
          "const": "highergraphen.test_semantics.interpretation_review.report.v1"
        },
        "candidate_id": {
          "$ref": "#/$defs/id"
        },
        "candidate_kind": {
          "$ref": "#/$defs/candidate_kind"
        },
        "reviewer_id": {
          "$ref": "#/$defs/id"
        },
        "test_run_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "candidate": {
          "$ref": "#/$defs/open_object"
        }
      }
    },
    "candidate_kind": {
      "enum": [
        "interpreted_cell",
        "interpreted_morphism",
        "candidate_law",
        "binding_candidate",
        "evidence_link"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "gates",
        "verified_candidate_ids",
        "unverified_candidate_ids",
        "accepted_fact_ids",
        "coverage_ids",
        "proof_obligation_ids",
        "semantic_proof_input_ids",
        "proof_object_ids",
        "verified_morphism_ids",
        "evidence_links",
        "verification_cells"
      ],
      "properties": {
        "status": {
          "enum": [
            "verified",
            "not_verified"
          ]
        },
        "gates": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/gate"
          }
        },
        "verified_candidate_ids": {
          "$ref": "#/$defs/string_array"
        },
        "unverified_candidate_ids": {
          "$ref": "#/$defs/string_array"
        },
        "accepted_fact_ids": {
          "$ref": "#/$defs/string_array"
        },
        "coverage_ids": {
          "$ref": "#/$defs/string_array"
        },
        "proof_obligation_ids": {
          "$ref": "#/$defs/string_array"
        },
        "semantic_proof_input_ids": {
          "$ref": "#/$defs/string_array"
        },
        "proof_object_ids": {
          "$ref": "#/$defs/string_array"
        },
        "verified_morphism_ids": {
          "$ref": "#/$defs/string_array"
        },
        "evidence_links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/open_object"
          }
        },
        "verification_cells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/open_object"
          }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "gate_type",
        "status",
        "summary",
        "source_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "gate_type": {
          "enum": [
            "review",
            "evidence",
            "semantic_binding"
          ]
        },
        "status": {
          "enum": [
            "passed",
            "failed"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "purpose",
        "summary",
        "recommended_actions",
        "source_ids",
        "information_loss"
      ],
      "properties": {
        "audience": {
          "const": "ai_agent"
        },
        "purpose": {
          "const": "test_semantics_verification"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_ids": {
          "$ref": "#/$defs/string_array"
        },
        "information_loss": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/information_loss"
          }
        }
      }
    },
    "information_loss": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "source_ids"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "open_object": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        }
      },
      "additionalProperties": true
    }
  }
}
