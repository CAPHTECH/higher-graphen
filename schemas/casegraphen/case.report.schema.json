{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.case.report.v1",
  "title": "HigherGraphen CaseGraphen Report Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_type",
    "report_version",
    "metadata",
    "input",
    "result",
    "projection"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "pattern": "^highergraphen\\.case\\.[a-z_]+\\.report\\.v1$"
    },
    "report_type": {
      "type": "string",
      "pattern": "^case_[a-z_]+$"
    },
    "report_version": {
      "const": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "tool_package",
        "core_packages"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "tool_package": {
          "const": "tools/casegraphen"
        },
        "core_packages": {
          "type": "array",
          "contains": {
            "const": "higher-graphen-core"
          }
        }
      }
    },
    "input": {
      "type": "object"
    },
    "result": {
      "type": "object"
    },
    "projection": {
      "type": "object",
      "required": [
        "human_review",
        "ai_view",
        "audit_trace"
      ],
      "properties": {
        "human_review": {
          "type": "object"
        },
        "ai_view": {
          "type": "object"
        },
        "audit_trace": {
          "type": "object"
        }
      }
    }
  }
}
