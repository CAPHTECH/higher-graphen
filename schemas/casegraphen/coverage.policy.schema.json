{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.case.coverage_policy.v1",
  "title": "HigherGraphen Case Coverage Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "policy_id"
  ],
  "properties": {
