{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.case.workflow.operation.report.v1",
  "title": "Focused CaseGraphen Workflow Operation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_type",
    "report_version",
    "metadata",
    "input",
    "result",
    "projection"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "pattern": "^highergraphen\\.case\\.workflow\\.[a-z_]+\\.report\\.v1$",
      "not": {
        "const": "highergraphen.case.workflow.report.v1"
      }
    },
    "report_type": {
      "type": "string",
      "pattern": "^case_workflow_[a-z_]+$"
    },
    "report_version": {
      "const": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "tool_package",
        "core_packages"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "tool_package": {
          "const": "tools/casegraphen"
        },
        "core_packages": {
          "type": "array",
          "contains": {
            "const": "higher-graphen-core"
          }
        }
      }
    },
    "input": {
      "type": "object"
    },
    "result": {
      "type": "object",
      "description": "Operation-specific workflow result payload. The shared operation envelope intentionally leaves most result fields broad; topology reports validate the optional result.higher_order fragment when present.",
      "properties": {
        "higher_order": {
          "$ref": "#/$defs/higher_order_topology"
        }
      }
    },
    "projection": {
      "$ref": "#/$defs/projection_bundle"
    }
  },
  "$defs": {
    "projection_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review",
        "ai_view",
        "audit_trace"
      ],
      "properties": {
        "human_review": {
          "type": "object"
        },
        "ai_view": {
          "type": "object"
        },
        "audit_trace": {
          "type": "object"
        }
      }
    },
    "higher_order_topology": {
      "type": "object",
      "description": "Optional higher-order topology diagnostics emitted only when --higher-order is supplied to workflow history topology.",
      "required": [
        "options",
        "cell_count",
        "stage_count"
      ],
      "properties": {
        "options": {
          "type": "object",
          "required": [
            "include_higher_order",
            "min_persistence_stages"
          ],
          "properties": {
            "include_higher_order": {
              "const": true
            },
            "max_dimension": {
              "type": "integer",
              "minimum": 0
            },
            "min_persistence_stages": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "cell_count": {
          "type": "integer",
          "minimum": 0
        },
        "stage_count": {
          "type": "integer",
          "minimum": 0
        },
        "persistence": {
          "$ref": "#/$defs/persistence_summary"
        },
        "omitted_reason": {
          "type": "string"
        }
      }
    },
    "persistence_summary": {
      "type": "object",
      "required": [
        "complex_id",
        "options",
        "stages",
        "intervals",
        "persistent_intervals",
        "open_component_count",
        "open_hole_count"
      ],
      "properties": {
        "complex_id": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "object",
          "required": [
            "min_lifetime_stages"
          ],
          "properties": {
            "min_lifetime_stages": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "stages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/filtration_stage_summary"
          }
        },
        "intervals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/persistence_interval"
          }
        },
        "persistent_intervals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/persistence_interval"
          }
        },
        "open_component_count": {
          "type": "integer",
          "minimum": 0
        },
        "open_hole_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "filtration_stage_summary": {
      "type": "object",
      "required": [
        "stage_id",
        "stage_index",
        "cell_ids",
        "topology"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_index": {
          "type": "integer",
          "minimum": 0
        },
        "cell_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "topology": {
          "type": "object"
        }
      }
    },
    "persistence_interval": {
      "type": "object",
      "required": [
        "dimension",
        "birth_stage_id",
        "birth_stage_index",
        "generator_cell_ids"
      ],
      "properties": {
        "dimension": {
          "type": "integer",
          "minimum": 0
        },
        "birth_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "birth_stage_index": {
          "type": "integer",
          "minimum": 0
        },
        "death_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "death_stage_index": {
          "type": "integer",
          "minimum": 0
        },
        "generator_cell_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
