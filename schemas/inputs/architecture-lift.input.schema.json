{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.architecture.input.v1",
  "title": "HigherGraphen Architecture Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source",
    "space",
    "contexts",
    "components",
    "relations"
  ],
  "properties": {
    "schema": {
      "const": "highergraphen.architecture.input.v1"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "space": {
      "$ref": "#/$defs/space"
    },
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context"
      },
      "minItems": 1
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      },
      "minItems": 1
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "inferred_structures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inference"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "confidence"
      ],
      "properties": {
        "kind": {
          "enum": [
            "document",
            "log",
            "api",
            "human",
            "ai",
            "code",
            "external"
          ]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "captured_at": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label",
        "context_id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "context_id": {
          "$ref": "#/$defs/id"
        },
        "source_local_id": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "from",
        "to",
        "orientation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "$ref": "#/$defs/id"
        },
        "to": {
          "$ref": "#/$defs/id"
        },
        "orientation": {
          "enum": [
            "directed",
            "undirected"
          ]
        },
        "weight": {
          "type": "number"
        },
        "source_local_id": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "inference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "missing_type",
        "structure_type",
        "summary",
        "rationale",
        "confidence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "missing_type": {
          "enum": [
            "cell",
            "incidence",
            "morphism",
            "constraint",
            "invariant",
            "section",
            "projection",
            "context"
          ]
        },
        "structure_id": {
          "$ref": "#/$defs/id"
        },
        "structure_type": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "related_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "inferred_from": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "context_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_local_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
