{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.pr_review_target.input.v1",
  "title": "HigherGraphen PR Review Target Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source",
    "repository",
    "pull_request",
    "changed_files"
  ],
  "properties": {
    "schema": {
      "const": "highergraphen.pr_review_target.input.v1"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "pull_request": {
      "$ref": "#/$defs/pull_request"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changed_file"
      },
      "minItems": 1
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol"
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/owner"
      }
    },
    "contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/test"
      }
    },
    "dependency_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency_edge"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk_signal"
      }
    },
    "reviewer_context": {
      "$ref": "#/$defs/reviewer_context"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "confidence"
      ],
      "properties": {
        "kind": {
          "enum": [
            "document",
            "log",
            "api",
            "human",
            "ai",
            "code",
            "external"
          ]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "captured_at": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "default_branch": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pull_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "title",
        "source_branch",
        "target_branch"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_branch": {
          "type": "string",
          "minLength": 1
        },
        "target_branch": {
          "type": "string",
          "minLength": 1
        },
        "author_id": {
          "$ref": "#/$defs/id"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "changed_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "change_type",
        "additions",
        "deletions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "change_type": {
          "enum": [
            "added",
            "modified",
            "deleted",
            "renamed"
          ]
        },
        "old_path": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "additions": {
          "type": "integer",
          "minimum": 0
        },
        "deletions": {
          "type": "integer",
          "minimum": 0
        },
        "symbol_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "owner_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "context_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "file_id",
        "name",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "file_id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "function",
            "method",
            "type",
            "module",
            "test",
            "configuration",
            "unknown"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "owner_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "context_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "owner_type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "owner_type": {
          "enum": [
            "person",
            "team",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "context_type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "context_type": {
          "enum": [
            "repository",
            "pull_request",
            "review_focus",
            "ownership",
            "test_scope",
            "dependency_scope",
            "custom"
          ]
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "test_type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "test_type": {
          "enum": [
            "unit",
            "integration",
            "e2e",
            "smoke",
            "manual",
            "unknown"
          ]
        },
        "file_id": {
          "$ref": "#/$defs/id"
        },
        "symbol_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "context_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "dependency_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from_id",
        "to_id",
        "relation_type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "from_id": {
          "$ref": "#/$defs/id"
        },
        "to_id": {
          "$ref": "#/$defs/id"
        },
        "relation_type": {
          "enum": [
            "imports",
            "calls",
            "owns",
            "tests",
            "covers",
            "depends_on",
            "generated_from",
            "custom"
          ]
        },
        "orientation": {
          "enum": [
            "directed",
            "undirected"
          ]
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "evidence_type",
        "summary",
        "source_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "evidence_type": {
          "enum": [
            "diff_hunk",
            "static_analysis",
            "test_result",
            "coverage",
            "ownership_metadata",
            "dependency_scan",
            "human_note",
            "ai_note",
            "custom"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "risk_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "signal_type",
        "summary",
        "source_ids",
        "severity",
        "confidence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "signal_type": {
          "enum": [
            "large_change",
            "test_gap",
            "dependency_change",
            "ownership_boundary",
            "security_sensitive",
            "generated_code",
            "custom"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "reviewer_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_expertise": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "declared_focus": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
