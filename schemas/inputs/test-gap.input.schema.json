          "$ref": "#/$defs/id_array"
        },
        "source_ids": {
          "$ref": "#/$defs/id_array"
        },
        "expected_verification": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
