      "items": {
        "$ref": "#/$defs/coverage"
      }
    },
    "dependency_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency_edge"
      }
    },
    "higher_order_cells": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/higher_order_cell"
      }
