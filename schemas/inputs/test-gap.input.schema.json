    "higher_order_incidences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/higher_order_incidence"
      }
    },
    "morphisms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/morphism"
      }
