{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.semantic_proof.input.v1",
  "title": "HigherGraphen Semantic Proof Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "source", "theorem", "verification_policy"],
  "properties": {
    "schema": { "const": "highergraphen.semantic_proof.input.v1" },
    "source": { "$ref": "#/$defs/source" },
    "theorem": { "$ref": "#/$defs/theorem" },
    "semantic_cells": {
      "type": "array",
      "items": { "$ref": "#/$defs/cell" }
    },
    "morphisms": {
      "type": "array",
      "items": { "$ref": "#/$defs/morphism" }
    },
    "laws": {
      "type": "array",
      "items": { "$ref": "#/$defs/law" }
    },
    "proof_certificates": {
      "type": "array",
      "items": { "$ref": "#/$defs/certificate" }
    },
    "counterexamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/counterexample" }
    },
    "verification_policy": { "$ref": "#/$defs/policy" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+\\-]*$"
    },
    "id_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "review_status": {
      "enum": ["unreviewed", "reviewed", "rejected", "accepted"]
    },
    "severity": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "confidence"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "confidence": { "$ref": "#/$defs/confidence" },
        "adapters": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "theorem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string", "minLength": 1 },
        "law_ids": { "$ref": "#/$defs/id_array" },
        "morphism_ids": { "$ref": "#/$defs/id_array" }
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "cell_type", "label"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "cell_type": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "source_ids": { "$ref": "#/$defs/id_array" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "morphism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "morphism_type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "morphism_type": { "type": "string", "minLength": 1 },
        "source_ids": { "$ref": "#/$defs/id_array" },
        "target_ids": { "$ref": "#/$defs/id_array" },
        "law_ids": { "$ref": "#/$defs/id_array" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "law": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string", "minLength": 1 },
        "applies_to_ids": { "$ref": "#/$defs/id_array" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "certificate_type",
        "backend",
        "backend_version",
        "theorem_id",
        "confidence",
        "review_status"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "certificate_type": { "type": "string", "minLength": 1 },
        "backend": { "type": "string", "minLength": 1 },
        "backend_version": { "type": "string", "minLength": 1 },
        "theorem_id": { "$ref": "#/$defs/id" },
        "law_ids": { "$ref": "#/$defs/id_array" },
        "morphism_ids": { "$ref": "#/$defs/id_array" },
        "witness_ids": { "$ref": "#/$defs/id_array" },
        "input_hash": { "type": "string", "minLength": 1 },
        "proof_hash": { "type": "string", "minLength": 1 },
        "confidence": { "$ref": "#/$defs/confidence" },
        "review_status": { "$ref": "#/$defs/review_status" }
      }
    },
    "counterexample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "counterexample_type",
        "theorem_id",
        "summary",
        "severity",
        "confidence",
        "review_status"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "counterexample_type": { "type": "string", "minLength": 1 },
        "theorem_id": { "$ref": "#/$defs/id" },
        "law_ids": { "$ref": "#/$defs/id_array" },
        "morphism_ids": { "$ref": "#/$defs/id_array" },
        "path_ids": { "$ref": "#/$defs/id_array" },
        "summary": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "review_status": { "$ref": "#/$defs/review_status" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accepted_backends": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "require_input_hash": { "type": "boolean" },
        "require_proof_hash": { "type": "boolean" },
        "require_accepted_review": { "type": "boolean" }
      }
    }
  }
}
