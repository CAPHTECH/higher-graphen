{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "highergraphen.test_semantics.input.v1",
  "title": "HigherGraphen Test Semantics Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "source", "files", "execution_cases"],
  "properties": {
    "schema": {
      "const": "highergraphen.test_semantics.input.v1"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "boundary"],
      "properties": {
        "kind": {
          "const": "code"
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "execution_cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/execution_case"
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "language", "tests"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test"
          }
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "assertions",
        "command_observations",
        "data_observations"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": ["unit", "integration", "property", "snapshot", "unknown"]
        },
        "assertions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "command_observations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_observation"
          }
        },
        "data_observations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_observation"
          }
        }
      }
    },
    "command_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "tokens"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "data_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "observation_type"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "observation_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "execution_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "matched_tests"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["passed", "failed", "ignored", "unknown"]
        },
        "matched_tests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
